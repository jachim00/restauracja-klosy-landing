# === Strona / SEO ===
# Ustawiane automatycznie w GitHub Actions dla GitHub Pages:
#   NEXT_PUBLIC_BASE_PATH=/restauracja-klosy-landing
#   NEXT_PUBLIC_SITE_URL=https://jachim00.github.io/restauracja-klosy-landing
# Lokalnie zostaw puste (strona działa na /).
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_SITE_URL=

# === Analityka (publiczne, wstrzykiwane do przeglądarki) ===
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=

# === Formularz (strona statyczna → wysyłka przez zewnętrzny webhook) ===
# Endpoint Make.com / Zapier / Formspree przyjmujący POST JSON ze zgłoszeniem.
# Jeśli pusty — formularz pokaże komunikat „nie podłączono" i NIE uda wysyłki.
NEXT_PUBLIC_LEAD_WEBHOOK_URL=
