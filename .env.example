# === Strona / SEO ===
# Ustawiane automatycznie w GitHub Actions dla GitHub Pages:
#   NEXT_PUBLIC_BASE_PATH=/restauracja-klosy-landing
#   NEXT_PUBLIC_SITE_URL=https://jachim00.github.io/restauracja-klosy-landing
# Lokalnie zostaw puste (strona działa na /).
NEXT_PUBLIC_BASE_PATH=
NEXT_PUBLIC_SITE_URL=

# === Analityka (publiczne, wstrzykiwane do przeglądarki) ===
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=

# === Formularz (strona statyczna) → e-mail na marketing@restauracjadifferent.pl ===
# ZALECANE: Web3Forms (web3forms.com). Załóż bezpłatny klucz dla adresu
# marketing@restauracjadifferent.pl i wklej go tutaj — zgłoszenia trafią na ten e-mail.
NEXT_PUBLIC_WEB3FORMS_KEY=
# Alternatywa: własny webhook (Make.com / Zapier) kierujący na ten sam adres.
NEXT_PUBLIC_LEAD_WEBHOOK_URL=
